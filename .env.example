# Browser key and matching server-side Clerk instance. Authorized parties are
# comma-separated exact HTTP(S) origins without trailing slashes.
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_AUTHORIZED_PARTIES=http://localhost:5173

# Server-only signing secret for POST /api/webhooks/clerk. Configure the
# endpoint for Clerk's user.deleted event; never use a VITE_ prefix.
CLERK_WEBHOOK_SIGNING_SECRET=

# Server-only Neon URLs injected by the Vercel Marketplace integration.
# Runtime queries use the pooled URL; migrations prefer the unpooled URL.
# Do not add VITE_ aliases for either value.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Server-side only. Never expose this key through Vite-prefixed variables.
OPENAI_API_KEY=

# API-6/NFR-5: use an immutable dated chat-model snapshot, not a mutable alias.
OPENAI_MODEL=gpt-4.1-mini-2025-04-14

# Optional separate pinned snapshot for photo inventory scans. When omitted,
# the backend uses OPENAI_MODEL.
OPENAI_VISION_MODEL=gpt-4.1-mini-2025-04-14

# OpenAI embeddings currently use a stable model id rather than a dated public
# snapshot. Pin the id explicitly and bump the deployment revision whenever the
# provider model/configuration changes so cached vectors are regenerated.
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_EMBED_REVISION=deployment-v1

# ALG-2 vocabulary vectors cache in a pgvector table in the same Neon
# database (§14 decision log, 2026-07-12). DATABASE_URL above is the switch:
# leave it unset to snap fully in-process instead. Rows are partitioned by
# OPENAI_EMBED_MODEL@OPENAI_EMBED_REVISION, so a revision bump regenerates
# them. The table ships with the drizzle migrations (npm run db:migrate).
